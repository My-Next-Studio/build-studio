{
  "name": "@build-studio/desktop",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "npm run build:next && npm run pack",
    "build:next": "cd ../hub && npx next build",
    "pack": "electron-builder --mac --dir",
    "inject-resources": "node inject-resources.js",
    "sync": "node inject-resources.js --sync-only",
    "dist": "npm run build"
  },
  "dependencies": {
    "@build-studio/shared": "*"
  },
  "devDependencies": {
    "electron": "39.8.10",
    "electron-builder": "^26"
  },
  "build": {
    "appId": "com.build-studio.app",
    "productName": "Build Studio",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dir"
      ],
      "identity": null,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Build Studio records narration from your microphone during demo recordings."
      },
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "files": [
      "main.js",
      "preload.js",
      "demo/**/*"
    ],
    "extraResources": [
      {
        "from": "../project-server",
        "to": "project-server",
        "filter": [
          "**/*",
          "!node_modules"
        ]
      },
      {
        "from": "../shared",
        "to": "shared",
        "filter": [
          "**/*",
          "!node_modules"
        ]
      },
      {
        "from": "../../templates",
        "to": "templates",
        "filter": [
          "**/*"
        ]
      }
    ],
    "afterPack": "./scripts/after-pack.js"
  }
}
