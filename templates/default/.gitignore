tmp/
node_modules/
.DS_Store

# Build Studio runtime state — ephemeral, machine-local, regenerated as workflows run
.build-studio/workflow-state.json
.build-studio/run-state.json
.build-studio/snapshots/
.build-studio/*.bak*
# Hub-written local overrides (Agents-tab CLI settings) — machine-local, like the
# enabled_clis list they depend on. Team-shared CLI defaults belong in config.yaml.
.build-studio/local.json
# OpenCode model catalog cache (GET /api/opencode/models)
.build-studio/opencode-models-cache.json
# Support reports (owner call: low archival value — the durable artifact is the filed backlog item)
.build-studio/support/
docs/agent-status.json

# Per-workflow agent launch artifacts
start.sh
start-*.sh
TASK.md
prompt-*.txt

# Test runner artifacts
test-results/
playwright-report/
